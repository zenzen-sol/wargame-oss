{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
        "BETTER_AUTH_DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "API_KEY_ENCRYPTION_SECRET",
        "AUTH_RESEND_KEY",
        "AUTH_EMAIL_FROM",
        "SUPABASE_JWT_SECRET",
        "SUPABASE_SECRET_KEY",
        "WORKFLOW_TRIGGER_URL",
        "WORKFLOW_AUTH_TOKEN",
        "MODEL_PROVIDER",
        "MODEL_LOW",
        "MODEL_BASELINE",
        "NEXT_PUBLIC_MAX_ISSUES_CAP",
        "NEXT_PUBLIC_MAX_TURNS_PER_ISSUE_CAP",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "LANGFUSE_BASE_URL",
        "LANGFUSE_PUBLIC_KEY",
        "LANGFUSE_SECRET_KEY",
        "NEXT_PUBLIC_SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN",
        "VERCEL_ENV",
        "NEXT_PUBLIC_VERCEL_ENV",
        "DEV_AUTH_BYPASS",
        "VERCEL_URL"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "env": ["PORT", "SAAS_PORT", "WORKFLOWS_PORT", "WORKFLOW_TRIGGER_URL"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
