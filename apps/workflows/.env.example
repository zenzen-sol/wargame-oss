# Local-dev env for the workflows app. Copy to `.env.local` here.

# Same as on the saas app — workflow steps use the admin client to
# bypass RLS for trusted writes.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Shared secret for the saas → workflows trigger handshake.
WORKFLOW_AUTH_TOKEN=local-dev-token

# BYOK — AES-256-GCM master key for decrypting user_api_keys rows.
# Must match API_KEY_ENCRYPTION_SECRET on the saas deploy or
# decryption fails. Generate with: openssl rand -hex 32
API_KEY_ENCRYPTION_SECRET=

# LLM (dev fallback only — production reads keys from user_api_keys
# via lib/byok.ts → getLLMCredsForProject). Same dev-bypass gate as
# saas.
MODEL_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_LOW=
MODEL_BASELINE=

# Optional Langfuse tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Sentry (error tracking). DSN is public; the other three are used
# at build time for source-map upload only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
