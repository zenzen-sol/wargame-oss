# Local-dev env for the saas Next.js app. Copy to `.env.local`
# (gitignored) inside this directory.

# ─────────────────────────────────────────────────────────────────────
# Better-Auth
# ─────────────────────────────────────────────────────────────────────

# Postgres connection used by Better-Auth's adapter only (Kysely +
# pg). Same database as Supabase, but accessed directly — Better-Auth
# manages its own tables (`user`, `session`, `account`, `verification`,
# `passkey`, `dev_otp_inbox`).
#
# Get from Supabase → Settings → Database → Connection string → URI.
# Replace [YOUR-PASSWORD] with your DB password.
#   postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
BETTER_AUTH_DATABASE_URL=

# Session signing secret. Better-Auth refuses to start in production
# with its default dev secret, so prod deployments MUST set this.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# The base URL the saas app is reachable at. Better-Auth validates
# the Origin header against this.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email-OTP via Resend. Skip in local dev when DEV_AUTH_BYPASS=1.
AUTH_RESEND_KEY=

# Verified sender for OTP emails. Format: "Display <addr@verified.domain>".
# The domain must be verified in Resend (https://resend.com/domains).
# `onboarding@resend.dev` is Resend's testing domain — it only sends
# to the Resend account owner's verified email, so any other recipient
# fails with 403. Not used when DEV_AUTH_BYPASS=1.
AUTH_EMAIL_FROM=

# Dev-only sign-in bypass. "1" writes OTPs to dev_otp_inbox;
# /api/dev/sign-in reads them back.
DEV_AUTH_BYPASS=1

# ─────────────────────────────────────────────────────────────────────
# Supabase (PostgREST + Storage)
# ─────────────────────────────────────────────────────────────────────

# HTTP API URL — labeled "Project URL" (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_…) — Settings → API → Publishable.
# The browser uses it as the base anon key; the JWT bridge provides
# the real authenticated identity per request.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_…) — server-only. Bypasses RLS for trusted
# writes (chat route's onFinish, workflow extraction, Storage admin).
SUPABASE_SECRET_KEY=

# Legacy JWT Secret. Settings → JWT Keys → Legacy JWT Secret → Reveal.
# Used by the JWT bridge (lib/supabase-jwt.ts) to mint Supabase-
# compatible JWTs from Better-Auth sessions, so RLS policies can
# read auth.uid() from `request.jwt.claims.sub`.
SUPABASE_JWT_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Workflow trigger (saas → workflows)
# ─────────────────────────────────────────────────────────────────────

WORKFLOW_TRIGGER_URL=http://localhost:3001/api
WORKFLOW_AUTH_TOKEN=local-dev-token

# ─────────────────────────────────────────────────────────────────────
# BYOK (Bring Your Own Key)
# ─────────────────────────────────────────────────────────────────────

# AES-256-GCM master key for encrypting user-supplied API keys at
# rest in user_api_keys. 32 bytes, hex-encoded (64 hex chars).
# Generate with: openssl rand -hex 32
# REQUIRED for any path that decrypts (chat route, extraction workflow).
# Rotating this invalidates every row in user_api_keys — there's no
# migration pathway. File the value somewhere safe (1Password etc).
API_KEY_ENCRYPTION_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Demo caps (optional)
# ─────────────────────────────────────────────────────────────────────
#
# Hard ceilings on the per-run tuning knobs, enforced server-side and
# mirrored by the setup form's sliders, whose stop scale ends at the
# cap (1–10 by ones, then tens, then hundreds). Leave unset to run
# uncapped — the default for self-hosted installs; the sliders then
# top out at a soft 100. The hosted demo sets 3 / 10 to bound LLM
# spend per run. NEXT_PUBLIC_ because the form reads them too; they
# are not secrets.
#NEXT_PUBLIC_MAX_ISSUES_CAP=3
#NEXT_PUBLIC_MAX_TURNS_PER_ISSUE_CAP=10

# ─────────────────────────────────────────────────────────────────────
# LLM (dev fallback only — production reads keys from user_api_keys)
# ─────────────────────────────────────────────────────────────────────
#
# In production, the chat route and extraction workflow look up the
# project's user's stored API key (see apps/saas/lib/byok.ts). These
# env vars are read ONLY when:
#   - DEV_AUTH_BYPASS=1 AND NODE_ENV !== "production"
#   - AND the user has no stored key for the requested provider
# That branch lets agent-driven tests run end-to-end locally without
# pasting personal credentials. Production must use BYOK.

MODEL_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional model-id overrides for either tier.
MODEL_LOW=
MODEL_BASELINE=

# ─────────────────────────────────────────────────────────────────────
# Sentry (error tracking)
# ─────────────────────────────────────────────────────────────────────
#
# Get the DSN from https://sentry.io/projects/<your-project>/settings/keys/
# DSNs are "public" — exposing them in the browser bundle is fine; they
# only identify the project, not credentials. The Sentry SDK silently
# no-ops if NEXT_PUBLIC_SENTRY_DSN is unset, so dev without a Sentry
# project stays quiet.
#
# SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN are used at build
# time to upload source maps so stack traces in the dashboard map to
# real file:line locations. Without them, stack traces reference
# minified files. Set on Vercel (Production + Preview) for source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
